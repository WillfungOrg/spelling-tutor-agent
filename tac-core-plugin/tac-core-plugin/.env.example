# ADW System Authentication Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Anthropic API Key
# ============================================
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# REQUIRED: GitHub Repository URL
# ============================================
# This should match your git remote origin
GITHUB_REPO_URL=https://github.com/willfung28/agentic-coding-library.git

# ============================================
# OPTIONAL: GitHub Personal Access Token
# ============================================
# Only needed if you want to use a different account than 'gh auth login'
# Create at: https://github.com/settings/tokens (with repo scope)
# If not set, ADW will use your 'gh auth login' credentials
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# OPTIONAL: Claude Code CLI Path
# ============================================
# Path to the claude executable
# Defaults to "claude" (assumes it's in your PATH)
# CLAUDE_CODE_PATH=/path/to/claude
