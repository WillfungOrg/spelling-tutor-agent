# ============================================
# Agentic Coding Library - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Required for Webhook Hub ===

# GitHub webhook secret (generated by start script if not exists)
# Location: ~/.adw/webhook_secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# === Claude Code Authentication (Choose ONE) ===

# Option 1: Claude Subscription OAuth Token (RECOMMENDED)
# Uses your Claude Pro/Max subscription instead of API charges
# Generate with: claude setup-token
# This will open browser and provide token starting with "sk-ant-oat01-"
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-oauth-token-here

# Option 2: Anthropic API Key (Alternative)
# Use Console API key (incurs API usage charges)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Webhook server port (default: 8000)
# Note: 8000 avoids conflict with macOS AirPlay on port 5000
PORT=8000

# === Required for ADW Workflows ===

# GitHub repository URL (used by workflows)
# Format: https://github.com/owner/repo.git
GITHUB_REPO_URL=https://github.com/your-org/your-repo.git

# GitHub Personal Access Token (recommended for API rate limits)
# Get from: https://github.com/settings/tokens
# Scopes needed: repo, workflow
GITHUB_PAT=ghp_your-personal-access-token-here

# === Optional Configuration ===

# Path to Claude Code CLI (defaults to 'claude')
CLAUDE_CODE_PATH=claude

# Model selection for workflows
# Options: base (default), heavy
# MODEL_SET=base

# === Runtime Configuration (Auto-generated) ===

# These are set by scripts and don't need manual configuration:
# - BACKEND_PORT (9100-9114, allocated per workflow)
# - FRONTEND_PORT (9200-9214, allocated per workflow)
# - ADW_ID (generated unique ID per workflow)

# ============================================
# Setup Notes
# ============================================
#
# 1. WEBHOOK_SECRET is auto-generated if missing when you run:
#    ./start_adw_services_simple.sh
#
# 2. For local development only, you can skip GITHUB_PAT
#    but you'll hit API rate limits faster
#
# 3. The webhook server URL changes on each restart when using
#    Cloudflare tunnel (temporary URLs). Update GitHub webhook
#    settings after each restart.
#
# 4. To use a custom domain instead of temporary URLs, see:
#    docs/CLOUDFLARE_TUNNEL_SETUP.md
#
